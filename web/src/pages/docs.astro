                <span class="terminal-title">.deepdoc.yaml</span>
              </div>
              <pre class="terminal-body">project_name: My API
description: "Internal API service for orders and fulfilment"

llm:
  provider: anthropic           <span class="c"># required</span>
  model: claude-opus-4-7        <span class="c"># optional — uses provider default if omitted</span>
  api_key_env: ANTHROPIC_API_KEY

generation_mode: feature_buckets  <span class="c"># v2 pipeline (default)</span>
max_parallel_workers: 6
output_dir: docs
