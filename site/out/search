id":"/database-models-schema-267","page_id":"/database-models-schema","tags":[],"type":"text","url":"/database-models-schema#relationships-summary","content":"has_many"},"996":{"id":"/database-models-schema-268","page_id":"/database-models-schema","tags":[],"type":"text","url":"/database-models-schema#relationships-summary","content":"ModelFileInfo"},"997":{"id":"/database-models-schema-269","page_id":"/database-models-schema","tags":[],"type":"text","url":"/database-models-schema#relationships-summary","content":"model_files"},"998":{"id":"/database-models-schema-270","page_id":"/database-models-schema","tags":[],"type":"text","url":"/database-models-schema#relationships-summary","content":"ArtifactScan"},"999":{"id":"/database-models-schema-271","page_id":"/database-models-schema","tags":[],"type":"text","url":"/database-models-schema#relationships-summary","content":"has_one"},"1000":{"id":"/database-models-schema-272","page_id":"/database-models-schema","tags":[],"type":"text","url":"/database-models-schema#relationships-summary","content":"DatabaseScan"},"1001":{"id":"/database-models-schema-273","page_id":"/database-models-schema","tags":[],"type":"text","url":"/database-models-schema#relationships-summary","content":"database_scan"},"1002":{"id":"/database-models-schema-274","page_id":"/database-models-schema","tags":[],"type":"text","url":"/database-models-schema#relationships-summary","content":"If you need a visual summary of these relationships, see the class diagram below:"},"1003":{"id":"/database-models-schema-275","page_id":"/database-models-schema","tags":[],"type":"text","url":"/database-models-schema#migrations","content":"DeepDoc does not use a traditional migration framework like Alembic. Instead, schema evolution is managed directly in code via the model definitions in deepdoc/scan_v2.py. When the schema changes, you must update the model classes and any downstream consumers."},"1004":{"id":"/database-models-schema-276","page_id":"/database-models-schema","tags":[],"type":"text","url":"/database-models-schema#migrations","content":"type: info"},"1005":{"id":"/database-models-schema-277","page_id":"/database-models-schema","tags":[],"type":"text","url":"/database-models-schema#migrations","content":"If you are integrating DeepDoc with a persistent database, you will need to write your own migration scripts or use a tool like Alembic to generate and apply migrations based on the SQLAlchemy models."},"1006":{"id":"/database-models-schema-278","page_id":"/database-models-schema","tags":[],"type":"text","url":"/database-models-schema#migrations","content":"For setup and environment configuration, see Setup & Getting Started."},"1007":{"id":"/database-models-schema-279","page_id":"/database-models-schema","tags":[],"type":"text","url":"/database-models-schema#query-patterns--performance","content":"Query Patterns:Most queries are in-memory traversals and aggregations, not SQL queries. For example, endpoint evidence is assembled by traversing the EndpointBundle and EvidenceUnit objects."},"1008":{"id":"/database-models-schema-280","page_id":"/database-models-schema","tags":[],"type":"text","url":"/database-models-schema#query-patterns--performance","content":"N+1 Risks:There are no N+1 query risks in the default implementation, as all data is loaded and processed in memory."},"1009":{"id":"/database-models-schema-281","page_id":"/database-models-schema","tags":[],"type":"text","url":"/database-models-schema#query-patterns--performance","content":"Heavy Joins:Not applicable; relationships are managed via Python lists, not SQL joins."},"1010":{"id":"/database-models-schema-282","page_id":"/database-models-schema","tags":[],"type":"text","url":"/database-models-schema#query-patterns--performance","content":"Denormalization:Some denormalization exists (e.g., storing symbol names and evidence strings redundantly) for performance and simplicity."},"1011":{"id":"/database-models-schema-283","page_id":"/database-models-schema","tags":[],"type":"text","url":"/database-models-schema#query-patterns--performance","content":"If you adapt DeepDoc for persistent storage, review your ORM query patterns to avoid N+1 issues and optimize for batch loading."},"1012":{"id":"/database-models-schema-284","page_id":"/database-models-schema","tags":[],"type":"text","url":"/database-models-schema#configuration","content":"DeepDoc does not require a database connection by default, as all data is managed in-memory via SQLAlchemy models. If you extend DeepDoc to use a persistent database, you must configure the connection string and pooling in your own integration layer."},"1013":{"id":"/database-models-schema-285","page_id":"/database-models-schema","tags":[],"type":"text","url":"/database-models-schema#configuration","content":"For environment setup and configuration, refer to Setup & Getting Started."},"1014":{"id":"/database-models-schema-286","page_id":"/database-models-schema","tags":[],"type":"text","url":"/database-models-schema#see-also","content":"High-level architecture, including the data model's role in the pipeline."},"1015":{"id":"/database-models-schema-287","page_id":"/database-models-schema","tags":[],"type":"text","url":"/database-models-schema#see-also","content":"How models are populated from source code and artifacts."},"1016":{"id":"/database-models-schema-288","page_id":"/database-models-schema","tags":[],"type":"text","url":"/database-models-schema#see-also","content":"How the database models feed into the documentation generation process."},"1017":{"id":"/database-models-schema-289","page_id":"/database-models-schema","tags":[],"type":"text","url":"/database-models-schema#see-also","content":"Integration discovery and evidence mapping."},"1018":{"id":"/database-models-schema-290","page_id":"/database-models-schema","tags":[],"type":"text","url":"/database-models-schema#see-also","content":"Example of integration identity usage."},"1019":{"id":"/development-notes","page_id":"/development-notes","type":"page","content":"Development Notes","tags":[],"url":"/development-notes"},"1020":{"id":"/development-notes-0","page_id":"/development-notes","tags":[],"type":"text","url":"/development-notes","content":"Auto-generated developer documentation"},"1021":{"id":"/development-notes-1","page_id":"/development-notes","type":"heading","tags":[],"url":"/development-notes#development-notes","content":"Development Notes"},"1022":{"id":"/development-notes-2","page_id":"/development-notes","type":"heading","tags":[],"url":"/development-notes#overview","content":"Overview"},"1023":{"id":"/development-notes-3","page_id":"/development-notes","type":"heading","tags":[],"url":"/development-notes#key-findings-or-terms","content":"Key Findings or Terms"},"1024":{"id":"/development-notes-4","page_id":"/development-notes","type":"heading","tags":[],"url":"/development-notes#timeline--references","content":"Timeline / References"},"1025":{"id":"/development-notes-5","page_id":"/development-notes","type":"heading","tags":[],"url":"/development-notes#relevance-to-the-codebase","content":"Relevance to the Codebase"},"1026":{"id":"/development-notes-6","page_id":"/development-notes","type":"heading","tags":[],"url":"/development-notes#architecture-flow-diagram","content":"Architecture Flow Diagram"},"1027":{"id":"/development-notes-7","page_id":"/development-notes","type":"heading","tags":[],"url":"/development-notes#see-also","content":"See Also"},"1028":{"id":"/development-notes-8","page_id":"/development-notes","type":"heading","tags":[],"url":"/development-notes#key_findings","content":"key_findings"},"1029":{"id":"/development-notes-9","page_id":"/development-notes","tags":[],"type":"text","url":"/development-notes#overview","content":"This page summarizes the repository-level development notes and design context for DeepDoc, as captured in README.md. It covers the architectural principles, key features, installation and setup workflows, and configuration conventions that underpin the DeepDoc system. Understanding these notes is essential for new developers onboarding to DeepDoc, as they clarify the rationale behind bucket-based documentation, the five-phase pipeline, and the integration of AI-driven planning and generation. This context also provides practical guidance for installation, configuration, and typical usage patterns, directly informing how you interact with the CLI, configure LLM providers, and manage documentation updates."},"1030":{"id":"/development-notes-10","page_id":"/development-notes","tags":[],"type":"text","url":"/development-notes#overview","content":"type: info"},"1031":{"id":"/development-notes-11","page_id":"/development-notes","tags":[],"type":"text","url":"/development-notes#key-findings-or-terms","content":"Bucket-Based Documentation ArchitectureDeepDoc organizes documentation into buckets: system, feature, endpoint, endpoint reference, integration, and database. This avoids the pitfalls of one-file-per-page output and enables logical grouping of related artifacts.Source: README.md: Features"},"1032":{"id":"/development-notes-12","page_id":"/development-notes","tags":[],"type":"text","url":"/development-notes#key-findings-or-terms","content":"Five-Phase PipelineThe documentation generation process is split into five phases:"},"1033":{"id":"/development-notes-13","page_id":"/development-notes","tags":[],"type":"text","url":"/development-notes#key-findings-or-terms","content":"Scan (repo walk and artifact detection)"},"1034":{"id":"/development-notes-14","page_id":"/development-notes","tags":[],"type":"text","url":"/development-notes#key-findings-or-terms","content":"Plan (multi-step AI bucket planner)"},"1035":{"id":"/development-notes-15","page_id":"/development-notes","tags":[],"type":"text","url":"/development-notes#key-findings-or-terms","content":"Generate (parallel page generation)"},"1036":{"id":"/development-notes-16","page_id":"/development-notes","tags":[],"type":"text","url":"/development-notes#key-findings-or-terms","content":"API Ref (OpenAPI asset staging)"},"1037":{"id":"/development-notes-17","page_id":"/development-notes","tags":[],"type":"text","url":"/development-notes#key-findings-or-terms","content":"Build (site generation with Fumadocs and Orama search)Source: README.md: Features, README.md: deepdoc generate"},"1038":{"id":"/development-notes-18","page_id":"/development-notes","tags":[],"type":"text","url":"/development-notes#key-findings-or-terms","content":"Multi-Language and Framework SupportDeepDoc parses Python, JavaScript, TypeScript, Go, PHP, and Vue, with high-confidence support for FastAPI, Flask, Laravel, Django/DRF, Express, Fastify, and Vue SFC.Source: README.md: Supported Languages & Frameworks"},"1039":{"id":"/development-notes-19","page_id":"/development-notes","tags":[],"type":"text","url":"/development-notes#key-findings-or-terms","content":"Incremental Updates and Safe Existing-Docs BehaviorThe deepdoc update command uses persisted plan and ledger data to regenerate only stale or structurally affected docs. Plain generate refuses to overwrite non-DeepDoc folders unless explicitly cleaned.Source: README.md: Features, README.md: deepdoc generate, README.md: deepdoc update"},"1040":{"id":"/development-notes-20","page_id":"/development-notes","tags":[],"type":"text","url":"/development-notes#key-findings-or-terms","content":"Configurable LLM ProvidersDeepDoc supports Anthropic, OpenAI, Azure OpenAI, Ollama, and any LiteLLM-compatible provider. Configuration is managed via .deepdoc.yaml and environment variables.Source: README.md: LLM Provider Setup, README.md: Configuration"},"1041":{"id":"/development-notes-21","page_id":"/development-notes","tags":[],"type":"text","url":"/development-notes#key-findings-or-terms","content":"Chatbot IntegrationDeepDoc can scaffold an AI-powered chatbot backend using FastAPI, FAISS, and Azure/OpenAI embedding models. Chatbot configuration is independent from the main LLM settings and is managed under the chatbot key in .deepdoc.yaml.Source: README.md: Chatbot"},"1042":{"id":"/development-notes-22","page_id":"/development-notes","tags":[],"type":"text","url":"/development-notes#key-findings-or-terms","content":"Generated Artifacts and Site StructureAfter generation, DeepDoc produces .deepdoc/ state, bucket plans, scan caches, and a Fumadocs-powered site in site/.Source: README.md: Generated Files"},"1043":{"id":"/development-notes-23","page_id":"/development-notes","tags":[],"type":"text","url":"/development-notes#key-findings-or-terms","content":"CI/CD and Release AutomationDeepDoc provides GitHub Actions workflows for automated doc updates and PyPI releases, with changelog-driven release notes.Source: README.md: GitHub Actions CI/CD, README.md: Releasing"},"1044":{"id":"/development-notes-24","page_id":"/development-notes","tags":[],"type":"text","url":"/development-notes#timeline--references","content":"Artifact / Section"},"1045":{"id":"/development-notes-25","page_id":"/development-notes","tags":[],"type":"text","url":"/development-notes#timeline--references","content":"File Path"},"1046":{"id":"/development-notes-26","page_id":"/development-notes","tags":[],"type":"text","url":"/development-notes#timeline--references","content":"Description"},"1047":{"id":"/development-notes-27","page_id":"/development-notes","tags":[],"type":"text","url":"/development-notes#timeline--references","content":"Features, pipeline, architecture"},"1048":{"id":"/development-notes-28","page_id":"/development-notes","tags":[],"type":"text","url":"/development-notes#timeline--references","content":"README.md"},"1049":{"id":"/development-notes-29","page_id":"/development-notes","tags":[],"type":"text","url":"/development-notes#timeline--references","content":"Key design decisions and workflow summary"},"1050":{"id":"/development-notes-30","page_id":"/development-notes","tags":[],"type":"text","url":"/development-notes#timeline--references","content":"Installation, quick 