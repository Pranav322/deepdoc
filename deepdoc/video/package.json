{
  "name": "deepdoc-video",
  "version": "1.0.0",
  "description": "Remotion explainer video for DeepDoc",
  "private": true,
  "scripts": {
    "start": "remotion studio",
    "render": "remotion render src/index.tsx DeepDocVideo --output ../../web/public/demo.mp4 --codec h264",
    "build": "remotion render src/index.tsx DeepDocVideo --output ../../web/public/demo.mp4 --codec h264"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "remotion": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.6.3"
  },
  "remotion": {
    "entryPoint": "src/index.tsx"
  }
}
