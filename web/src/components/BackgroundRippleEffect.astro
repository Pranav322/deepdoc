---
const rows = 8;
const cols = 27;
const cellSize = 56;
---

<!-- Sentinel so Tailwind scans animate-cell-ripple -->
<span class="animate-cell-ripple hidden" aria-hidden="true"></span>

<div
  id="ripple-bg"
  aria-hidden="true"
  style={`position:absolute;inset:0;overflow:hidden;pointer-events:none;z-index:0;`}
>
  <div
    id="ripple-grid"
    style={`
      display:grid;
      grid-template-columns:repeat(${cols},${cellSize}px);
      grid-template-rows:repeat(${rows},${cellSize}px);
      width:${cols * cellSize}px;
      height:${rows * cellSize}px;
      margin-inline:auto;
      mask-image:radial-gradient(ellipse 90% 100% at 50% 0%, black 30%, transparent 100%);
      -webkit-mask-image:radial-gradient(ellipse 90% 100% at 50% 0%, black 30%, transparent 100%);
    `}
  ></div>
</div>

<script define:vars={{ rows, cols }}>
  const grid = document.getElementById('ripple-grid');
  grid.style.pointerEvents = 'auto';

  const isLight = () =>
    document.documentElement.getAttribute('data-theme') === 'light';

  function cellColors() {
    return isLight()
      ? { bg: 'rgba(236,234,228,0.6)', border: 'rgba(0,0,0,0.09)' }
      : { bg: 'rgba(16,16,26,0.5)',    border: 'rgba(255,255,255,0.06)' };
  }

  const cells = [];

  for (let i = 0; i < rows * cols; i++) {
    const div = document.createElement('div');
    const { bg, border } = cellColors();
    div.style.cssText = `
      background-color:${bg};
      border:0.5px solid ${border};
      opacity:0.4;
      transition:opacity 150ms;
      will-change:transform;
      cursor:pointer;
    `;
    cells.push(div);
    grid.appendChild(div);

    const row = Math.floor(i / cols);
    const col = i % cols;

    div.addEventListener('click', () => {
      cells.forEach((cell, idx) => {
        const r = Math.floor(idx / cols);
        const c = idx % cols;
        const dist = Math.hypot(row - r, col - c);
        cell.style.setProperty('--delay',    `${Math.max(0, dist * 55)}ms`);
        cell.style.setProperty('--duration', `${200 + dist * 80}ms`);
        cell.classList.remove('animate-cell-ripple');
        void cell.offsetWidth;
        cell.classList.add('animate-cell-ripple');
      });
    });

    div.addEventListener('mouseenter', () => { div.style.opacity = '0.85'; });
    div.addEventListener('mouseleave', () => { div.style.opacity = '0.4'; });
  }

  function applyColors() {
    const { bg, border } = cellColors();
    cells.forEach(cell => {
      cell.style.backgroundColor = bg;
      cell.style.borderColor = border;
    });
  }

  new MutationObserver(applyColors).observe(
    document.documentElement,
    { attributes: true, attributeFilter: ['data-theme'] }
  );
</script>
