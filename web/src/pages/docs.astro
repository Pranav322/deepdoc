---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const nav = [
  { id: "quick-start",    label: "Quick Start" },
  { id: "architecture",   label: "Architecture" },
  { id: "pipeline",       label: "Five-Phase Pipeline" },
  { id: "data-models",    label: "Data Models" },
  { id: "configuration",  label: "Configuration" },
  { id: "cli",            label: "CLI Reference" },
  { id: "bucket-types",   label: "Bucket Types" },
  { id: "languages",      label: "Supported Languages" },
  { id: "chatbot",        label: "Chatbot" },
  { id: "updates",        label: "Incremental Updates" },
  { id: "deployment",     label: "Deployment" },
  { id: "modules",        label: "Module Reference" },
];

const pipeline = [
  {
    step: "Scan",
    num: "01",
    color: "var(--color-accent)",
    desc: "Traverse the repo without any LLM calls. Detects HTTP endpoints (Django, FastAPI, Express, NestJS, Laravel, Go, Falcon), runtime surfaces (async workers, schedulers, Celery), third-party integrations, database schemas (SQL, Knex, GraphQL), OpenAPI specs, and config artifacts.",
    output: "RepoScan — endpoints, symbols, routes, integrations, artifacts",
  },
  {
    step: "Plan",
    num: "02",
    color: "#67E8F9",
    desc: "Multi-step LLM bucket planner (3 sequential LLM calls). Step 1: classify the repo type. Step 2: propose documentation buckets. Step 3: inject specialised buckets (database groups, runtime pages, integration pages). Then heuristics refine ownership: assign files/symbols, decompose oversized buckets, consolidate singletons.",
    output: "DocPlan — ordered bucket list, nav structure, orphaned files",
  },
  {
    step: "Generate",
    num: "03",
    color: "#A5B4FC",
    desc: "For each bucket: assemble an evidence pack (source snippets, artifact extracts, scan hits), call the LLM, receive Markdown. Python-side repair runs immediately — on failure the LLM is reprompted with quality feedback. Nothing broken ever hits disk.",
    output: "Markdown pages on disk, per-page quality status, generation quality log",
  },
  {
    step: "API Ref",
    num: "04",
    color: "#C4B5FD",
    desc: "When an OpenAPI spec is found during scan, stage the raw JSON/YAML and render a single interactive Swagger UI page via mkdocs-swagger-ui-tag.",
    output: "docs/api.md — Swagger UI page from staged OpenAPI specs",
  },
  {
    step: "Build",
    num: "05",
    color: "#86EFAC",
    desc: "Write the MkDocs Material scaffold: site/mkdocs.yml (Material theme, Mermaid superfence, pymdownx Blocks), extra.css brand stylesheet, landing page grid cards, and nav structure from the plan. When chatbot is enabled, the chatbot backend runs alongside via deepdoc serve.",
    output: "site/ — a configurable MkDocs Material project (pure Python)",
  },
];

const bucketTypes = [
  { type: "system",        color: "var(--color-accent)", desc: "Top-level architecture, setup guides, auth flows, observability, and ops runbooks. Every repo gets at least one." },
  { type: "feature",       color: "#A5B4FC", desc: "Business-logic workflows: checkout, refunds, onboarding, notifications. Scoped to how engineers think about the domain, not how files are laid out." },
  { type: "endpoint",      color: "#67E8F9", desc: "Endpoint-family API docs. One bucket per logical resource (e.g. all /orders/* routes). Enriched with scanned route metadata." },
  { type: "endpoint_ref",  color: "#8B5CF6", desc: "Single-endpoint page backed by an OpenAPI spec. Rendered as part of the Swagger UI API reference page." },
  { type: "integration",   color: "#86EFAC", desc: "Third-party system docs: payment gateways, delivery providers, webhook consumers, external APIs. Auto-detected from import patterns." },
  { type: "database",      color: "#FDE68A", desc: "Schema and data-layer docs. Grouped by model family when a repo has many models; a single overview page for smaller schemas." },
];

const cliCommands = [
  {
    cmd: "deepdoc init",
    flags: [
      { flag: "--provider", val: "anthropic | openai | gemini | …", desc: "LLM provider (required). Sets llm.provider in .deepdoc.yaml." },
      { flag: "--model", val: "string", desc: "Override the default model for the chosen provider." },
      { flag: "--with-chatbot", val: "flag", desc: "Enable the chatbot module. Adds chatbot config block with sensible defaults." },
      { flag: "--output-dir", val: "path", desc: "Where generated Markdown pages land. Default: docs/" },
      { flag: "--site-dir", val: "path", desc: "Where the MkDocs site config is written. Default: site/" },
    ],
    desc: "Scaffold a .deepdoc.yaml config file in the current directory. Safe to re-run — only missing keys are added.",
  },
  {
    cmd: "deepdoc generate",
    flags: [
      { flag: "--force", val: "flag", desc: "Ignore existing state and regenerate everything from scratch." },
      { flag: "--reconcile", val: "flag", desc: "Re-run planning then regenerate pages whose bucket assignment changed." },
      { flag: "--dry-run", val: "flag", desc: "Run scan + plan only, print the proposed bucket list, exit without generating." },
      { flag: "--workers", val: "int", desc: "Override max_parallel_workers for this run." },
    ],
    desc: "Run the full five-phase pipeline. Reads .deepdoc.yaml. On success prints per-phase timings and a page-quality summary.",
  },
  {
    cmd: "deepdoc update",
    flags: [
      { flag: "--since", val: "git-ref", desc: "Compare against this ref instead of the stored sync baseline." },
      { flag: "--replan", val: "flag", desc: "Force a full replan even if the changed file set is small." },
    ],
    desc: "Incremental update. Diffs the repo against the last synced commit. Regenerates only affected buckets; triggers a targeted replan when new routes or integrations appear.",
  },
  {
    cmd: "deepdoc serve",
    flags: [
      { flag: "--port", val: "int", desc: "HTTP port for the MkDocs dev server. Default: 3000." },
      { flag: "--open", val: "flag", desc: "Open the browser automatically after starting." },
    ],
    desc: "Run mkdocs serve against site/mkdocs.yml. Pure Python — no Node.js required.",
  },
  {
    cmd: "deepdoc deploy",
    flags: [
      { flag: "--branch", val: "string", desc: "Target GitHub Pages branch. Default: gh-pages." },
      { flag: "--force", val: "flag", desc: "Force-push to the deploy branch." },
    ],
    desc: "Build the MkDocs Material site (mkdocs build) and export static HTML to site/out/. Pure Python, no Node.js.",
  },
];

const configKeys = [
  { key: "project_name",         dflt: "(repo dir name)",   desc: "Human-readable project name used in site title and nav header." },
  { key: "description",          dflt: '""',                desc: "One-line summary shown in hero and meta description." },
  { key: "output_dir",         dflt: '"docs"',            desc: "Where generated Markdown pages are written." },
  { key: "site_dir",             dflt: '"site"',            desc: "Where the MkDocs site config is written." },
  { key: "generation_mode",      dflt: '"feature_buckets"', desc: 'v2 bucket-based pipeline. Set "file_centric" for legacy v1 mode.' },
  { key: "max_pages",            dflt: "0",                 desc: "Cap on total pages generated. 0 = unlimited." },
  { key: "max_parallel_workers", dflt: "6",                 desc: "Concurrent LLM calls during generate phase." },
  { key: "llm.provider",         dflt: "(required)",        desc: "LLM provider: anthropic, openai, gemini, azure, ollama, …" },
  { key: "llm.model",            dflt: "(provider default)",desc: "Model name. Passed directly to LiteLLM." },
  { key: "llm.api_key_env",      dflt: "auto-detected",     desc: "Env var name holding the API key. Inferred from provider if omitted." },
  { key: "llm.temperature",      dflt: "0.2",               desc: "Generation temperature. Lower = more deterministic output." },
  { key: "chatbot.enabled",      dflt: "false",             desc: "Enable chatbot indexing and the /ask route in the built site." },
  { key: "chatbot.answer.provider", dflt: "(inherits llm)", desc: "Separate provider for chatbot answer calls." },
  { key: "chatbot.embeddings.provider", dflt: '"fastembed"',desc: "Embedding provider. fastembed runs 100% locally — no API key." },
  { key: "chatbot.embeddings.model", dflt: "nomic-embed-text-v1.5", desc: "Local embedding model for fastembed. Downloaded once on first run." },
  { key: "large_file_lines",     dflt: "500",               desc: "Files above this threshold get chunked before evidence assembly." },
  { key: "giant_file_lines",     dflt: "2000",              desc: "Files above this threshold are split into symbol clusters." },
  { key: "source_context_budget", dflt: "200000",           desc: "Max chars of source included in a single evidence pack." },
];

const modules = [
  {
    path: "deepdoc/scanner/",
    role: "Phase 1 — static analysis",
    exports: ["discover_integrations()", "discover_database_schema()", "discover_runtime_surfaces()", "discover_artifacts()", "cluster_giant_file()"],
    note: "Zero LLM calls. Extracts every signal that the planner and generator consume as evidence.",
  },
  {
    path: "deepdoc/planner/",
    role: "Phase 2 — bucket planning",
    exports: ["plan_docs(repo_root, cfg) → DocPlan", "scan_repo(repo_root, cfg) → RepoScan", "build_flow_candidates()", "_merge_plan()", "_build_heuristic_assignment()", "_llm_step()"],
    note: "heuristics.py is the public planning API. Tests mock at this path. engine.py orchestrates the multi-step planner.",
  },
  {
    path: "deepdoc/generator/",
    role: "Phase 3 — Markdown generation",
    exports: ["PageGenerator", "BucketGenerationEngine", "AssembledEvidence", "apply_mdx_compile_gate()"],
    note: "post_processors.py handles Markdown repair, fence fixes, and Mermaid diagram fixups after generation.",
  },
  {
    path: "deepdoc/parser/",
    role: "Symbol & route extraction",
    exports: ["parse_file(path, language) → ParsedFile", "ParsedFile", "Symbol", "supported_extensions()"],
    note: "routes/ sub-package has per-framework detectors: Django, FastAPI, Express, NestJS, Laravel, Falcon, Go. repo_resolver.py auto-detects the framework.",
  },
  {
    path: "deepdoc/chatbot/",
    role: "RAG indexing + query service",
    exports: ["ChatbotIndexer", "ChatbotQueryService", "create_fastapi_app()"],
    note: "retrieval_mixin.py owns all search logic. answer_mixin.py owns LLM prompting. service.py wires query(), deep_research(), code_deep().",
  },
  {
    path: "deepdoc/site/builder/",
    role: "Phase 5 — scaffold generation",
    exports: ["build_mkdocs_from_plan()"],
    note: "mkdocs_builder.py emits the MkDocs Material project: site/mkdocs.yml, extra.css, and landing page.",
  },
  {
    path: "deepdoc/llm/",
    role: "LLM provider abstraction",
    exports: ["LLMClient(cfg)"],
    note: "Thin wrapper around LiteLLM. Supports every provider LiteLLM supports: OpenAI, Anthropic, Gemini, Azure, Mistral, Ollama, …",
  },
  {
    path: "deepdoc/persistence_v2.py",
    role: "State persistence",
    exports: ["load_ledger()", "save_ledger()", "load_sync_state()", "save_sync_state()"],
    note: "All state lives under .deepdoc/. Ledger tracks per-page quality. Sync state stores the last-generated git commit hash.",
  },
  {
    path: "deepdoc/smart_update_v2.py",
    role: "Incremental update strategy",
    exports: ["compute_update_plan()", "run_smart_update()"],
    note: "Diffs changed files against the sync baseline, classifies impact (new route? new integration?), decides which buckets to regenerate.",
  },
];
---

<Layout
  title="Docs — DeepDoc"
  description="Full engineering reference for DeepDoc — architecture, setup, CLI, chatbot, and deployment."
>
  <Header />

  <!-- ── Page hero ───────────────────────────────────────────────── -->
  <div style="border-bottom: 1px solid var(--color-line);">
    <div class="mx-auto max-w-6xl px-6 py-16 md:py-20">
      <div style="font-family: var(--font-mono); font-size: 11px; text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-ink-faint); margin-bottom: 10px;">
        Documentation
      </div>
      <h1 class="display" style="font-size: clamp(2rem, 5vw, 3.25rem); color: var(--color-ink);">
        Engineering <span class="accent-italic">Reference.</span>
      </h1>
      <p style="margin-top: 14px; max-width: 560px; font-family: var(--font-sans); font-size: 15px; line-height: 1.75; color: var(--color-ink-muted);">
        Everything you need to install, configure, run, and extend DeepDoc — from the five-phase
        pipeline internals to chatbot retrieval and GitHub Pages deployment.
      </p>
      <div
        class="mt-6 inline-flex items-center gap-2 rounded-full px-3 py-1"
        style="border: 1px solid var(--color-line-strong); font-family: var(--font-mono); font-size: 11px; color: var(--color-ink-faint);"
      >
        <span class="h-1.5 w-1.5 rounded-full" style="background: var(--color-accent);"></span>
        v3.0.0 — stable · Python 3.10+ · MIT
      </div>
    </div>
  </div>

  <!-- ── Two-column layout ───────────────────────────────────────── -->
  <div class="mx-auto max-w-7xl px-6 py-12">
    <div class="flex gap-12 lg:gap-16">

      <!-- Sidebar -->
      <aside class="hidden w-52 shrink-0 lg:block">
        <nav class="sticky top-20 flex flex-col gap-0.5" id="docs-nav" aria-label="Page sections">
          {nav.map((item) => (
            <a
              href={`#${item.id}`}
              class="docs-nav-link rounded-md px-2.5 py-1.5 text-sm text-[var(--color-ink-faint)] transition-colors hover:text-[var(--color-ink)]"
              data-section={item.id}
            >
              {item.label}
            </a>
          ))}
        </nav>
      </aside>

      <!-- Main content -->
      <main class="min-w-0 flex-1">
        <div class="flex flex-col gap-20">

          <!-- ── QUICK START ───────────────────────────────────────── -->
          <section id="quick-start">
            <div class="mb-3 font-mono text-xs uppercase tracking-[0.18em] text-[var(--color-ink-faint)]">
              01
            </div>
            <h2 class="mb-2 text-2xl font-semibold tracking-tight text-[var(--color-ink)] md:text-3xl">
              Quick Start
            </h2>
            <p class="mb-8 text-base leading-relaxed text-[var(--color-ink-muted)]">
              Three commands to go from repo to a live docs site with an optional AI chatbot.
            </p>

            <!-- Step cards -->
            <div class="flex flex-col gap-6">

              <!-- Step 1 -->
              <div class="rounded-2xl border border-[var(--color-line)] bg-[var(--color-surface-raised)]/50 p-6">
                <div class="mb-4 flex items-center gap-3">
                  <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[var(--color-accent-dim)] font-mono text-xs font-semibold text-[var(--color-accent)]">1</span>
                  <h3 class="text-base font-semibold text-[var(--color-ink)]">Install the package</h3>
                </div>
                <div class="terminal-block">
                  <div class="terminal-header">
                    <div class="flex gap-1.5"><span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span></div>
                    <span class="terminal-title">bash</span>
                  </div>
                  <pre class="terminal-body"><span class="c"># Python 3.10+ required</span>
pip install deepdoc

<span class="c"># With chatbot dependencies (FAISS, FastAPI, fastembed)</span>
pip install "deepdoc[chatbot]"</pre>
                </div>
                <p class="mt-4 text-sm leading-relaxed text-[var(--color-ink-muted)]">
                  The base install pulls in LiteLLM, GitPython, Click, Rich, PyYAML, and Jinja2.
                  The <code class="inline-code">[chatbot]</code> extra adds faiss-cpu, fastapi, uvicorn, httpx, and fastembed for local embeddings.
                </p>
              </div>

              <!-- Step 2 -->
              <div class="rounded-2xl border border-[var(--color-line)] bg-[var(--color-surface-raised)]/50 p-6">
                <div class="mb-4 flex items-center gap-3">
                  <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[var(--color-accent-dim)] font-mono text-xs font-semibold text-[var(--color-accent)]">2</span>
                  <h3 class="text-base font-semibold text-[var(--color-ink)]">Initialise against your repo</h3>
                </div>
                <div class="terminal-block">
                  <div class="terminal-header">
                    <div class="flex gap-1.5"><span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span></div>
                    <span class="terminal-title">bash</span>
                  </div>
                  <pre class="terminal-body"><span class="c"># cd into your target codebase first</span>
cd /path/to/your-repo

<span class="c"># Initialize — writes .deepdoc.yaml with sensible defaults</span>
deepdoc init --provider anthropic

<span class="c"># Add --with-chatbot to enable the /ask Q&amp;A interface</span>
deepdoc init --provider openai --with-chatbot

<span class="c"># Set your API key (matches llm.api_key_env in .deepdoc.yaml)</span>
export ANTHROPIC_API_KEY=sk-ant-...</pre>
                </div>
                <p class="mt-4 text-sm leading-relaxed text-[var(--color-ink-muted)]">
                  <code class="inline-code">init</code> is safe to re-run — it only adds keys that are missing. The generated
                  <code class="inline-code">.deepdoc.yaml</code> lives in your repo root and should be committed.
                </p>
              </div>

              <!-- Step 3 -->
              <div class="rounded-2xl border border-[var(--color-line)] bg-[var(--color-surface-raised)]/50 p-6">
                <div class="mb-4 flex items-center gap-3">
                  <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[var(--color-accent-dim)] font-mono text-xs font-semibold text-[var(--color-accent)]">3</span>
                  <h3 class="text-base font-semibold text-[var(--color-ink)]">Generate and preview</h3>
                </div>
                <div class="terminal-block">
                  <div class="terminal-header">
                    <div class="flex gap-1.5"><span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span></div>
                    <span class="terminal-title">bash</span>
                  </div>
                  <pre class="terminal-body"><span class="c"># Full pipeline — scan, plan, generate, build</span>
deepdoc generate

<span class="acc">✓</span> Scan complete        — 312 files · 47 endpoints · 8 integrations
<span class="acc">✓</span> Plan complete        — 34 buckets across 6 sections
<span class="acc">✓</span> Generate complete    — 34 pages · 2 Markdown fixes applied
<span class="acc">✓</span> Chatbot index built  — 1,247 chunks · 4.2 MB FAISS index
<span class="acc">✓</span> Site scaffold written → site/

  Phase timings:  scan 4s · plan 18s · generate 72s · build 3s

<span class="c"># Preview locally (pure Python — no Node.js required)</span>
deepdoc serve

  Docs   → http://localhost:3000
  Chat   → http://localhost:3000/ask</pre>
                </div>
              </div>

            </div>
          </section>

          <!-- ── ARCHITECTURE ──────────────────────────────────────── -->
          <section id="architecture">
            <div class="mb-3 font-mono text-xs uppercase tracking-[0.18em] text-[var(--color-ink-faint)]">
              02
            </div>
            <h2 class="mb-2 text-2xl font-semibold tracking-tight text-[var(--color-ink)] md:text-3xl">
              Architecture
            </h2>
            <p class="mb-8 text-base leading-relaxed text-[var(--color-ink-muted)]">
              DeepDoc is a stateful, five-phase pipeline. Each phase has a single responsibility and
              a well-defined output contract. Nothing is hand-edited inside <code class="inline-code">docs/</code>,
              <code class="inline-code">site/</code>, or <code class="inline-code">.deepdoc/</code> — all
              fixes go into generators, builders, or prompts.
            </p>

            <!-- Architecture diagram — clean SVG -->
            <div class="overflow-hidden rounded-2xl border border-[var(--color-line)] bg-[var(--color-surface-raised)]/50">
              <div class="border-b border-[var(--color-line)] px-5 py-3">
                <span class="font-mono text-xs text-[var(--color-ink-faint)]">System overview</span>
              </div>
              <div class="overflow-x-auto p-4 md:p-6">
                <svg viewBox="0 0 740 480" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-2xl mx-auto" style="font-family:ui-monospace,SFMono-Regular,Menlo,monospace">
                  <defs>
                    <marker id="arr" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto">
                      <path d="M0,0 L6,3 L0,6 Z" fill="#C2FF4D" opacity="0.7"/>
                    </marker>
                    <marker id="arr-faint" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto">
                      <path d="M0,0 L6,3 L0,6 Z" fill="#525252"/>
                    </marker>
                  </defs>

                  <!-- ── Your repo ── -->
                  <rect x="295" y="14" width="150" height="36" rx="8" fill="#111" stroke="rgba(255,255,255,0.12)" stroke-width="1"/>
                  <text x="370" y="37" text-anchor="middle" fill="#ededed" font-size="12" font-weight="600">Your repo</text>

                  <!-- arrow down to pipeline -->
                  <line x1="370" y1="50" x2="370" y2="74" stroke="#C2FF4D" stroke-width="1" opacity="0.5" marker-end="url(#arr)"/>

                  <!-- ── Pipeline container ── -->
                  <rect x="20" y="78" width="700" height="192" rx="12" fill="rgba(194,255,77,0.03)" stroke="rgba(194,255,77,0.18)" stroke-width="1"/>
                  <text x="370" y="98" text-anchor="middle" fill="rgba(194,255,77,0.5)" font-size="10" letter-spacing="3">DEEPDOC GENERATE</text>

                  <!-- Phase boxes -->
                  <!-- Scan -->
                  <rect x="38" y="110" width="120" height="68" rx="8" fill="#0a0a0a" stroke="rgba(255,255,255,0.1)" stroke-width="1"/>
                  <text x="98" y="132" text-anchor="middle" fill="#525252" font-size="9">01</text>
                  <text x="98" y="150" text-anchor="middle" fill="#ededed" font-size="13" font-weight="600">Scan</text>
                  <text x="98" y="168" text-anchor="middle" fill="#525252" font-size="10">no LLM</text>

                  <!-- Plan -->
                  <rect x="198" y="110" width="120" height="68" rx="8" fill="#0a0a0a" stroke="rgba(255,255,255,0.1)" stroke-width="1"/>
                  <text x="258" y="132" text-anchor="middle" fill="#525252" font-size="9">02</text>
                  <text x="258" y="150" text-anchor="middle" fill="#ededed" font-size="13" font-weight="600">Plan</text>
                  <text x="258" y="168" text-anchor="middle" fill="#525252" font-size="10">3×LLM</text>

                  <!-- Generate -->
                  <rect x="358" y="110" width="120" height="68" rx="8" fill="#0a0a0a" stroke="rgba(255,255,255,0.1)" stroke-width="1"/>
                  <text x="418" y="132" text-anchor="middle" fill="#525252" font-size="9">03</text>
                  <text x="418" y="150" text-anchor="middle" fill="#ededed" font-size="13" font-weight="600">Generate</text>
                  <text x="418" y="168" text-anchor="middle" fill="#525252" font-size="10">N×LLM</text>

                  <!-- API Ref -->
                  <rect x="518" y="110" width="120" height="68" rx="8" fill="#0a0a0a" stroke="rgba(255,255,255,0.1)" stroke-width="1"/>
                  <text x="578" y="132" text-anchor="middle" fill="#525252" font-size="9">04</text>
                  <text x="578" y="150" text-anchor="middle" fill="#ededed" font-size="13" font-weight="600">API Ref</text>
                  <text x="578" y="168" text-anchor="middle" fill="#525252" font-size="10">OpenAPI</text>

                  <!-- Build -->
                  <rect x="298" y="210" width="144" height="48" rx="8" fill="#0a0a0a" stroke="rgba(255,255,255,0.1)" stroke-width="1"/>
                  <text x="370" y="228" text-anchor="middle" fill="#525252" font-size="9">05</text>
                  <text x="370" y="247" text-anchor="middle" fill="#ededed" font-size="13" font-weight="600">Build</text>

                  <!-- Arrows between phases -->
                  <line x1="158" y1="144" x2="192" y2="144" stroke="#C2FF4D" stroke-width="1" opacity="0.5" marker-end="url(#arr)"/>
                  <line x1="318" y1="144" x2="352" y2="144" stroke="#C2FF4D" stroke-width="1" opacity="0.5" marker-end="url(#arr)"/>
                  <line x1="478" y1="144" x2="512" y2="144" stroke="#C2FF4D" stroke-width="1" opacity="0.5" marker-end="url(#arr)"/>

                  <!-- Arrow from Generate down to Build -->
                  <line x1="418" y1="178" x2="418" y2="206" stroke="#C2FF4D" stroke-width="1" opacity="0.4"/>
